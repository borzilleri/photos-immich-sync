<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.rampant.photos-immich-sync.delta</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/photos-immich-sync</string>
    <string>immich-delta</string>
    <string>--quiet</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>3</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>RunAtLoad</key><false/>
  <key>ProcessType</key><string>Background</string>
  <key>LowPriorityIO</key><true/>
  <key>Nice</key><integer>5</integer>

  <!-- launchd does not expand ~ or $HOME in these paths.
       Substitute __HOME__ with your actual home (e.g. /Users/<username>) before installing. -->
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/photos-immich-sync/delta.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/photos-immich-sync/delta.err.log</string>
</dict>
</plist>
